# Copy this to .env.local and fill in your values

# Get from Convex Dashboard after running `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Get from Clerk Dashboard → Settings → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=

# Get from YouTube Data API Console
YOUTUBE_API_KEY=

# Get from Resend Dashboard (resend.com)
RESEND_API_KEY=

# Church notification emails
ADMIN_EMAIL=contact@lilliputsda.org
PRAYER_TEAM_EMAIL=prayer@lilliputsda.org
FROM_EMAIL=Lilliput SDA <noreply@lilliputsda.org>
