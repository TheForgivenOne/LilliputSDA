# Copy this to .env.development and fill in your values

# Database
# For SQLite (local dev): DATABASE_URL="file:./prisma/dev.db"
# For PostgreSQL (production): postgresql://...

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Get from YouTube Data API Console
YOUTUBE_API_KEY=

# Get from Resend Dashboard (resend.com)
RESEND_API_KEY=

# Church notification emails
ADMIN_EMAIL=contact@lilliputsda.org
PRAYER_TEAM_EMAIL=prayer@lilliputsda.org
FROM_EMAIL=Lilliput SDA <noreply@lilliputsda.org>

# Get from Upstash Console (upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here