# Google Analytics (GA4 — only loads in production, leave empty to disable)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Public site URL (for OG/Twitter metadata canonical URLs)
NEXT_PUBLIC_SITE_URL=https://lilliputsda.org
# NextAuth configuration
NEXTAUTH_URL=https://lilliputsda.vercel.app
# Generate a secret via `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Church phone number (unused - contact via email instead)
# NEXT_PUBLIC_CHURCH_PHONE=

# Copy this to .env.development and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://...

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://lilliputsda.vercel.app

# Get from YouTube Data API Console
YOUTUBE_API_KEY=

# Get from Resend Dashboard (resend.com)
RESEND_API_KEY=

# Church notification emails
ADMIN_EMAIL=admin@lilliputsda.org
PRAYER_TEAM_EMAIL=lhamilton@westjamaica.org
FROM_EMAIL=Lilliput SDA <noreply@lilliputsda.org>

# Get from Upstash Console (upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Additional allowed dev origins (comma-separated, for Vercel preview/remote dev)
# Example: ALLOWED_DEV_ORIGINS=192.168.1.100,150.136.61.22
ALLOWED_DEV_ORIGINS=