# Copy this to .env.local and fill in your values

# Get from Convex Dashboard after running `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Get from Clerk Dashboard → Settings → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=

# Clerk JWT Issuer (for Convex auth - get from Clerk Dashboard → API Keys)
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev

# Get from YouTube Data API Console
YOUTUBE_API_KEY=

# Get from Resend Dashboard (resend.com)
RESEND_API_KEY=

# Church notification emails
ADMIN_EMAIL=contact@lilliputsda.org
PRAYER_TEAM_EMAIL=prayer@lilliputsda.org
FROM_EMAIL=Lilliput SDA <noreply@lilliputsda.org>

# Get from Upstash Console (upstash.com)
# Create a Redis database and copy the REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Clerk Webhook Secret (get from Clerk Dashboard → Webhooks)
CLERK_WEBHOOK_SECRET=
