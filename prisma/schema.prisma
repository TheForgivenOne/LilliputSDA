generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
  ministries    Ministry[] @relation("MinistryLeader")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  date      DateTime
  category  String   @default("general")
  priority  String   @default("normal")
  imageUrl  String?
  expiresAt DateTime?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, isPinned])
  @@index([category])
}

model Event {
  id                String   @id @default(cuid())
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime?
  location          String?
  category          String   @default("service")
  imageUrl          String?
  isRecurring       Boolean  @default(false)
  recurrencePattern String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([startDate])
  @@index([category])
}

model Ministry {
  id              String   @id @default(cuid())
  name            String
  description     String
  category        String   @default("adult")
  imageUrl        String?
  leaderId        String?
  leader          User?    @relation("MinistryLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  meetingTime     String?
  meetingLocation String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
}

model Staff {
  id         String   @id @default(cuid())
  name       String
  title      String
  role       String?
  department String?
  email      String?
  phone      String?
  photoUrl   String?
  bio        String?
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, order])
  @@index([department])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  date      DateTime @default(now())
  isRead    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@index([isRead, date])
}

model PrayerRequest {
  id         String   @id @default(cuid())
  name       String
  email      String?
  request    String
  isPublic   Boolean  @default(false)
  isAnswered Boolean  @default(false)
  date       DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublic, isAnswered])
  @@index([date])
}

model Decision {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  decision      String
  isAdventist   String?
  ageGroup      String?
  address       String?
  parish        String?
  country       String?
  prayerRequest String?
  comments      String?
  source        String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([isRead, createdAt])
}

model Media {
  id           String   @id @default(cuid())
  name         String
  url          String
  blobPathname String?
  type         String   @default("image")
  size         Int?
  uploadedAt   DateTime @default(now())

  @@index([type])
  @@index([uploadedAt])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?
  memberSince String?
  content     String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  content   String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}